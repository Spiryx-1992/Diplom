
Процедура ОтправитьУведомленияИзСправочника()
	
	// + Работа с заявками клиентов. Обслуживание клиентов. Пункт 15.
	
	Запрос = Новый Запрос;
    Запрос.Текст = "ВЫБРАТЬ
                   |	ВКМ_УведомленияТелеграмБоту.Ссылка КАК Ссылка,
                   |	ВКМ_УведомленияТелеграмБоту.ТекстСообщения КАК ТекстСообщения
                   |ИЗ
                   |	Справочник.ВКМ_УведомленияТелеграмБоту КАК ВКМ_УведомленияТелеграмБоту";

    Результат = Запрос.Выполнить();
    Выборка = Результат.Выбрать();

    Пока Выборка.Следующий() Цикл
		
		УспешноОтправлено = ОтправитьВTelegram(Выборка.ТекстСообщения);

        Если УспешноОтправлено Тогда
			
			ЭлементСправочника = Выборка.Ссылка.ПолучитьОбъект();
            ЭлементСправочника.Удалить(); 
			
		КонецЕсли; 
		
	КонецЦикла;
	
	// - Работа с заявками клиентов. Обслуживание клиентов. Пункт 15.
	
КонецПроцедуры

Функция ОтправитьВTelegram(ТекстСообщения)
	
	Попытка
		
		ТокенБота = "ВАШ_ТОКЕН_БОТА"; // Замените на реальный токен
        ChatID = "ВАШ_CHAT_ID"; // Замените на ID чата/канала

        URL = "https://api.telegram.org/bot" + ТокенБота + "/sendMessage";

        Параметры = Новый Соответствие;
        Параметры.Вставить("chat_id", ChatID);
        Параметры.Вставить("text", ТекстСообщения);

        HTTP = Новый HTTPСоединение("api.telegram.org", 443);
        Ответ = HTTP.ОтправитьДляОбработки(Новый HTTPЗапрос(URL, "POST"), Параметры);

        Если Ответ.КодСостояния = 200 Тогда
            Возврат Истина;
        Иначе
            ЗаписьЖурналаРегистрации("ОШИБКА_ОТПРАВКИ_TELEGRAM",
                УровеньЖурналаРегистрации.Ошибка,
                , "Ошибка отправки: " + Ответ.КодСостояния);
            Возврат Ложь;
		КонецЕсли;
		
    Исключение
		
		ЗаписьЖурналаРегистрации("ИСКЛЮЧЕНИЕ_ОТПРАВКИ_TELEGRAM",
            УровеньЖурналаРегистрации.Ошибка,, ОписаниеОшибки());
        Возврат Ложь; 
		
	КонецПопытки;
	
КонецФункции 

