
Процедура ОтправитьСообщениеВТелеграм(ТекстСообщения) Экспорт

	Токен = Константы.ВКМ_ТокенУправленияТелеграмБотом.Получить();
	ChatID = Константы.ВКМ_ИдентификаторГруппыДляОповещения.Получить();

	Если ПустаяСтрока(Токен) Тогда
		ЗаписьЖурналаРегистрации("Ошибка интеграции с Telegram: не задан токен в константе ТокенТелеграма", УровеньЖурналаРегистрации.Ошибка);
		Возврат;
	КонецЕсли;

	Если ПустаяСтрока(ChatID) Тогда
		ЗаписьЖурналаРегистрации("Ошибка интеграции с Telegram: не задан идентификатор группы в константе ИдентификаторГруппыТелеграма", УровеньЖурналаРегистрации.Ошибка);
		Возврат;
	КонецЕсли;

	URLПуть = "/bot" + Токен + "/sendMessage";

	Соединение = Новый HTTPСоединение("api.telegram.org", 443, Неопределено, Неопределено, 10, 10);

	Запрос = Новый HTTPЗапрос(URLПуть);
	Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");

	ТелоJSON = "{""chat_id"": """ + ChatID + """, ""text"": """ + ЭкранироватьДляJSON(ТекстСообщения) + """}";

	Запрос.УстановитьТелоИзСтроки(ТелоJSON, "UTF-8");

	Попытка
		Ответ = Соединение.ОтправитьЗапрос(Запрос);
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("Ошибка HTTP-запроса к Telegram: " + ТекстОшибки, УровеньЖурналаРегистрации.Ошибка);
		Возврат;
	КонецПопытки;

	КодСостояния = Ответ.КодСостояния;

	Если КодСостояния <> 200 Тогда
		
		ТелоОтвета = Ответ.ПолучитьТелоКакСтроку();
		СообщениеОбОшибке = "Ошибка Telegram API: код состояния " + КодСостояния + ", ответ сервера: " + ТелоОтвета;
		ЗаписьЖурналаРегистрации(СообщениеОбОшибке, УровеньЖурналаРегистрации.Ошибка);
		
	КонецЕсли;

КонецПроцедуры 

Функция ЭкранироватьДляJSON(ИсходнаяСтрока)
	
	Результат = СтрЗаменить(ИсходнаяСтрока, "\", "\\");
	Результат = СтрЗаменить(Результат, """", "\""");
	Результат = СтрЗаменить(Результат, Символы.ПС, "\n");
	Возврат Результат; 
	
КонецФункции

